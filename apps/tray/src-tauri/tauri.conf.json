{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pace",
  "version": "0.2.0",
  "identifier": "dev.pace.tray",
  "build": {
    "beforeBuildCommand": "node build-ui.mjs",
    "beforeDevCommand": "node build-ui.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Pace",
        "width": 420,
        "height": 640,
        "resizable": true,
        "visible": false,
        "skipTaskbar": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
